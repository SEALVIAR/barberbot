    {
      "parameters": {
        "jsCode": "const llm = $input.first().json;\n\nlet data = llm.output ?? llm.text ?? llm.response ?? llm;\n\nif (typeof data === 'string') {\n  data = data.replace(/```json/g, '').replace(/```/g, '').trim();\n  data = JSON.parse(data);\n}\n\n// Como tu nodo todavía se llama \"Edit Fields\", usamos ese nombre\nconst entrada = $('Edit Fields').first().json;\n\nconst duracion = data.duracion || 30;\n\nlet start_datetime = null;\nlet end_datetime = null;\n\nif (data.fecha && data.hora) {\n  start_datetime = `${data.fecha}T${data.hora}:00-05:00`;\n\n  end_datetime = new Date(\n    new Date(start_datetime).getTime() + duracion * 60000\n  ).toISOString();\n}\n\nreturn [\n  {\n    json: {\n      ...entrada,\n      intencion: data.intencion,\n      servicio: data.servicio,\n      fecha: data.fecha,\n      hora: data.hora,\n      duracion,\n      respuesta_sugerida: data.respuesta_sugerida,\n      start_datetime,\n      end_datetime\n    }\n  }\n];"
      },
